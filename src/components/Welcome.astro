<div id="vl-intro" aria-hidden="true">
<svg
  id="vl-svg"
  xmlns="http://www.w3.org/2000/svg"
  xmlns:xlink="http://www.w3.org/1999/xlink"
  viewBox="80 312 1765 470"
  class="vl-wordmark overflow-visible"
  aria-label="Virtex Labs"
  role="img"
>
  <defs>
    <clipPath id="vl-clip-v">
      <polygon points="442.45 322.77 301.74 645.96 186.38 376.55 87.45 376.55 251.71 759.45 375.57 759.45 581.34 322.77 442.45 322.77"/>
    </clipPath>

    <clipPath id="vl-clip-box">
      <rect x="87.45" y="322.77" width="493.89" height="436.69"/>
    </clipPath>

    <linearGradient id="vl-shimmer-grad" gradientUnits="userSpaceOnUse"
                    x1="-300" y1="0" x2="0" y2="0">
      <stop offset="0%"   stop-color="white" stop-opacity="0"/>
      <stop offset="50%"  stop-color="white" stop-opacity="0.7"/>
      <stop offset="100%" stop-color="white" stop-opacity="0"/>
    </linearGradient>
  </defs>

  <text
    id="vl-labs"
    transform="translate(568.3 759.45)"
    font-family="EurostileExt-Med, 'Eurostile Extd', sans-serif"
    font-size="156.33"
    letter-spacing="0.45em"
    fill="black"
    opacity="0"
  >LABS</text>

  <g id="vl-irtex" fill="black" opacity="0">

    <!-- i (dot + stem as two rects) -->
    <path d="M610.37,367.13v-44.37h63.34v44.37h-63.34Z
             M610.37,572.92v-144.64h63.34v144.64h-63.34Z"/>

    <!-- r -->
    <path d="M702.75,322.77,764.07,468.57l-61.32-.08v-39.93h49.36c32.01,0,51.99-1.02,59.96-3.07,7.96-2.05,14.2-5.57,18.71-10.58,4.51-5,6.76-11.26,6.76-18.77,0-8.42-2.97-15.21-8.9-20.39-5.94-5.17-14.31-8.45-25.13-9.81-5.41-.57-21.64-.85-48.69-.85h-52.07v-42.32s73.71,0,73.71,0c35.31,0,60.97,2.25,76.97,6.74,16,4.5,28.81,12.49,38.43,23.97,9.61,11.49,14.43,24.63,14.43,39.42,0,18.77-7.29,34.27-21.86,46.5-14.58,12.23-36.37,19.94-65.37,23.12l114.05,110.4h-79.79l-89.25-104.35Z"/>

    <!-- t -->
    <path d="M1060.19,570.7v-207.84h-98.05v-42.32h262.59v42.32
             h-97.82v207.84h-66.72Z"/>

    <!-- e (three horizontal bars) -->
    <path d="M1253.77,322.77h230.16v42.32h-230.16l.36-42.32Z
             M1253.77,424.55h230.16v42.15h-230.16v-42.15Z
             M1253.77,530.77h230.16v42.15h-230.16v-42.15Z"/>

    <!-- x -->
    <path d="M1451.75,759.45h-82.9l269.16-317.84-102.34-118.85h79.83
             l110.53,118.85-274.27,317.84Z
             M1730.35,456.48l102.2,116.44h-80.47l-61.33-72.43,39.6-44.01Z
             M1692.48,387.91l52.61-65.14h77.31l-91.42,108.06-38.51-42.92Z"/>
  </g>

  <g id="vl-v" opacity="0">

    <g clip-path="url(#vl-clip-v)">
      <g clip-path="url(#vl-clip-box)">
        <image
          width="1030" height="911"
          transform="translate(87.36 322.56) scale(.48)"
          xlink:href="data:image/png;base64,"
        />
      </g>
    </g>

    <rect
      id="vl-shimmer"
      clip-path="url(#vl-clip-v)"
      fill="url(#vl-shimmer-grad)"
      x="87" y="322" width="494" height="437"
    />
  </g>
</svg>
</div>

<style>
  #vl-intro {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
  }

  .vl-wordmark {
    display: block;
    width: min(76vw, 920px);
    height: auto;
  }

  @media (max-width: 640px) {
    .vl-wordmark {
      width: min(88vw, 560px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #vl-intro {
      display: none;
    }
  }
</style>

<script>
  import gsap from 'gsap';
  import { detect, isMobile } from 'get-browser';

  const intro = document.getElementById('vl-intro');
  const svg = document.getElementById('vl-svg');
  const navBrand = document.querySelector('.nav-brand');
  const LOGO_EVENT = 'vl-logo-complete';
  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const userAgent = navigator.userAgent || '';
  const browserInfo = detect({ userAgent });
  const mobileDevice = isMobile({ userAgent });

  // Disable scrolling during animation
  document.body.style.overflow = 'hidden';

  function finishLogoIntro() {
    window.__vlLogoDone = true;
    document.body.style.overflow = ''; // Restore scrolling
    window.dispatchEvent(new CustomEvent(LOGO_EVENT));
  }

  if (prefersReduced) {
    gsap.set(['#vl-v', '#vl-labs', '#vl-irtex'], { attr: { opacity: 1 } });
    finishLogoIntro();
  } else if (intro && svg) {
    gsap.set(intro, { opacity: 1 });
    gsap.set(svg, { transformOrigin: '50% 50%' });
    gsap.set('#vl-v', { attr: { opacity: 0 }, scale: 0.96, transformOrigin: '24% 50%' });
    gsap.set('#vl-irtex', { attr: { opacity: 0, transform: 'translate(64 0)' } });
    gsap.set('#vl-labs', { attr: { opacity: 0, transform: 'translate(378.3 759.45)' } });

    const tl = gsap.timeline({
      delay: 0.2,
      defaults: { ease: 'power3.out' },
      onComplete: finishLogoIntro,
    });

    tl
      .to('#vl-v', { attr: { opacity: 1 }, scale: 1, duration: 0.62 })

      .to('#vl-shimmer-grad', {
        attr: { x1: 581, x2: 881 },
        duration: 0.95,
        ease: 'power1.inOut',
      }, '-=0.1')

      .fromTo(
        '#vl-irtex',
        { attr: { opacity: 0, transform: 'translate(64 0)' } },
        { attr: { opacity: 1, transform: 'translate(0 0)' }, duration: 0.70 },
        '-=0.42'
      )

      .fromTo(
        '#vl-labs',
        { attr: { opacity: 0, transform: 'translate(378.3 759.45)' } },
        { attr: { opacity: 1, transform: 'translate(568.3 759.45)' }, duration: 0.80 },
        '-=0.08'
      )
      .add(() => {
        const svgRect = svg.getBoundingClientRect();
        const brandRect = navBrand?.getBoundingClientRect();
        const targetX = brandRect
          ? brandRect.left + brandRect.width / 2 - (svgRect.left + svgRect.width / 2)
          : 0;
        const targetY = brandRect
          ? brandRect.top + brandRect.height / 2 - (svgRect.top + svgRect.height / (mobileDevice ? 2.6 : 2.5))
          : -window.innerHeight / 2 + 58;
        const targetScale = brandRect
          ? Math.min(brandRect.width / svgRect.width, brandRect.height / svgRect.height) * (mobileDevice ? 0.495 : 0.437)
          : 0.18;

        gsap.to(svg, {
          x: targetX,
          y: targetY,
          scale: targetScale,
          duration: 0.6,
          ease: 'power3.inOut',
        });
      })
      .to(intro, { opacity: 0, duration: 0.22, delay: 0.72 }, '<');
  } else {
    finishLogoIntro();
  }
</script>

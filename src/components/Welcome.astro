<style>
  #vl-intro {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    background-color: #fcf2f6;
  }

  .vl-wordmark {
    display: block;
    width: min(76vw, 920px);
    height: auto;
  }

  @media (max-width: 640px) {
    .vl-wordmark {
      width: min(88vw, 560px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #vl-intro {
      display: none;
    }
  }
</style>

<script>
  import gsap from "gsap";
  import { detect, isMobile } from "get-browser";

  function initWelcome() {
    const intro = document.getElementById("vl-intro");
    const svg = document.getElementById("vl-svg");
    const navBrand = document.querySelector(".nav-brand");

    const LOGO_EVENT = "vl-logo-complete";
    const FLY_EVENT = "vl-logo-flying";

    const prefersReduced = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;

    const userAgent = navigator.userAgent || "";
    const browserInfo = detect({ userAgent });
    const mobileDevice = isMobile({ userAgent });

    function finishLogoIntro() {
      window.__vlLogoDone = true;
      document.body.style.overflow = "";
      window.dispatchEvent(new CustomEvent(LOGO_EVENT));
    }

    if (!intro) return;

    if (
      prefersReduced ||
      window.__vlLogoDone === true ||
      (window.location.pathname.includes("/faq") &&
        document.referrer.includes(window.location.hostname))
    ) {
      intro.style.display = "none";
      gsap.set(["#vl-v", "#vl-labs", "#vl-irtex"], { attr: { opacity: 1 } });
      finishLogoIntro();
    } else if (svg) {
      document.body.style.overflow = "hidden";
      gsap.set(intro, { opacity: 1 });
      gsap.set(svg, { transformOrigin: "50% 50%" });
      gsap.set("#vl-v", {
        attr: { opacity: 0 },
        scale: 0.96,
        transformOrigin: "24% 50%",
      });
      gsap.set("#vl-irtex", {
        attr: { opacity: 0, transform: "translate(64 0)" },
      });
      gsap.set("#vl-labs", {
        attr: { opacity: 0, transform: "translate(378.3 759.45)" },
      });

      const tl = gsap.timeline({
        delay: 0.2,
        defaults: { ease: "power3.out" },
      });

      tl.to("#vl-v", { attr: { opacity: 1 }, scale: 1, duration: 0.62 })
        .to(
          "#vl-shimmer-grad",
          { attr: { x1: 581, x2: 881 }, duration: 0.95, ease: "power1.inOut" },
          "-=0.1",
        )
        .fromTo(
          "#vl-irtex",
          { attr: { opacity: 0, transform: "translate(64 0)" } },
          { attr: { opacity: 1, transform: "translate(0 0)" }, duration: 0.7 },
          "-=0.42",
        )
        .fromTo(
          "#vl-labs",
          { attr: { opacity: 0, transform: "translate(378.3 759.45)" } },
          {
            attr: { opacity: 1, transform: "translate(568.3 759.45)" },
            duration: 0.8,
          },
          "-=0.08",
        )
        .add(() => {
          const svgRect = svg.getBoundingClientRect();
          const brandRect = navBrand?.getBoundingClientRect();

          let offsetX = 0;
          let offsetYDivider = 2.5;
          let scaleMult = mobileDevice ? 0.05 : 0.4;

          if (window.innerWidth <= 768) {
            offsetX = 0;
            offsetYDivider = 4.5;
            scaleMult = 0.95;
          }

          const targetX = brandRect
            ? brandRect.left +
              brandRect.width / 2 -
              (svgRect.left + svgRect.width / 2) +
              offsetX
            : 0;

          const targetY = brandRect
            ? brandRect.top +
              brandRect.height / (mobileDevice ? 4.8 : 3.8) -
              (svgRect.top + svgRect.height / offsetYDivider)
            : -window.innerHeight / 2 + 58;

          const targetScale = brandRect
            ? Math.min(
                brandRect.width / svgRect.width,
                brandRect.height / svgRect.height,
              ) * scaleMult
            : 0.18;

          window.dispatchEvent(new CustomEvent(FLY_EVENT));

          gsap.to(svg, {
            x: targetX,
            y: targetY,
            scale: targetScale,
            duration: 0.8,
            ease: "power3.inOut",
          });

          gsap.to(svg, {
            opacity: 0,
            duration: 0.2,
            delay: 0.7,
          });

          gsap.to(intro, {
            opacity: 0,
            duration: 0.4,
            delay: 0.6,
            onComplete: finishLogoIntro,
          });
        });
    } else {
      finishLogoIntro();
    }
  }

  document.addEventListener("astro:page-load", initWelcome);
</script>

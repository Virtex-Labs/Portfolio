<style>
  .a-word-1,
  .a-word-2 {
    opacity: 0;
    visibility: hidden;
  }

  /* Icons start hidden below */
  .float-icon {
    opacity: 0;
    will-change: transform, opacity;
  }

  /* The infinite float keyframes, each icon gets a different duration/delay via JS */
  @keyframes floatA {
    0%,
    100% {
      translate: 0px 0px;
    }
    33% {
      translate: 6px -10px;
    }
    66% {
      translate: -5px 5px;
    }
  }
  @keyframes floatB {
    0%,
    100% {
      translate: 0px 0px;
    }
    40% {
      translate: -8px -8px;
    }
    70% {
      translate: 4px 6px;
    }
  }
  @keyframes floatC {
    0%,
    100% {
      translate: 0px 0px;
    }
    25% {
      translate: 5px 8px;
    }
    75% {
      translate: -6px -5px;
    }
  }

  .float-icon.is-floating:nth-child(odd) {
    animation: floatA var(--float-dur, 5s) ease-in-out infinite
      var(--float-del, 0s);
  }
  .float-icon.is-floating:nth-child(even) {
    animation: floatB var(--float-dur, 6s) ease-in-out infinite
      var(--float-del, 0s);
  }
  .float-icon.is-floating:nth-child(3n) {
    animation: floatC var(--float-dur, 7s) ease-in-out infinite
      var(--float-del, 0s);
  }

  @media (prefers-reduced-motion: reduce) {
    .a-word-1,
    .a-word-2 {
      opacity: 1 !important;
      visibility: visible !important;
      transform: none !important;
    }
    .float-icon {
      opacity: 0.25 !important;
      transform: none !important;
      animation: none !important;
    }
  }
</style>

<script>
  import gsap from "gsap";
  import ScrollTrigger from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  let ctx: gsap.Context | undefined;

  // Randomise float speed/phase per icon so they never move in sync
  const floatDurations = [4.8, 6.2, 5.5, 7.1, 5.9, 6.7, 4.4];
  const floatDelays = [0, 0, 0, 0, 0, 0, 0];

  function initAboutAnimation() {
    ctx?.revert();

    const about = document.querySelector<HTMLElement>("#about");
    if (!about) return;

    const words1 = gsap.utils.toArray<HTMLElement>(".a-word-1", about);
    const words2 = gsap.utils.toArray<HTMLElement>(".a-word-2", about);
    const icons = gsap.utils.toArray<HTMLElement>(".float-icon", about);
    if (!words1.length || !words2.length) return;

    const prefersReduced = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;

    ctx = gsap.context(() => {
      if (prefersReduced) {
        gsap.set(words1, { autoAlpha: 1, yPercent: 0 });
        gsap.set(words2, { autoAlpha: 1, yPercent: 0 });
        return;
      }

      gsap.set(words1, { autoAlpha: 1, yPercent: 110 });
      gsap.set(words2, { autoAlpha: 1, yPercent: 110 });

      // Stamp each icon's float CSS vars before any animation
      icons.forEach((icon, i) => {
        icon.style.setProperty(
          "--float-dur",
          `${floatDurations[i % floatDurations.length]}s`,
        );
        icon.style.setProperty(
          "--float-del",
          `${floatDelays[i % floatDelays.length]}s`,
        );
      });

      // ── Main scroll timeline (words only, unchanged) ───────────────────────
      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: about,
          start: "top top",
          end: "+=250%",
          scrub: 1,
          pin: true,
          onEnter: () => revealIcons(),
        },
        defaults: { ease: "power3.out" },
      });

      tl.to(words1, { yPercent: 0, duration: 1.2, stagger: 0.12 })
        .to({}, { duration: 0.8 })
        .to(words1, {
          yPercent: -110,
          duration: 1.2,
          stagger: 0.12,
          ease: "power3.in",
        })
        .to({}, { duration: 0.2 })
        .to(words2, { yPercent: 0, duration: 1.2, stagger: 0.12 })
        .to({}, { duration: 1.5 });

      ScrollTrigger.refresh();
    }, about);
  }

  function revealIcons() {
    const icons = gsap.utils.toArray(".float-icon");
    icons.forEach((icon, i) => {
      // PREVENT SNAPPING: If it's already floating, do nothing.
      if (icon.classList.contains("is-floating")) return;

      const delay = parseFloat(icon.dataset.floatDelay || "0");

      // Use fromTo so GSAP knows exactly where to start the Y position
      gsap.fromTo(
        icon,
        { y: 60, opacity: 0 },
        {
          opacity: 0.55,
          y: 0,
          duration: 0.9,
          ease: "power3.out",
          delay: delay * 0.4,
          onComplete: () => {
            icon.classList.add("is-floating");
          },
        },
      );
    });
  }

  document.addEventListener("astro:after-swap", () => ctx?.revert());
  document.addEventListener("astro:page-load", initAboutAnimation);

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initAboutAnimation, {
      once: true,
    });
  } else {
    initAboutAnimation();
  }
</script>

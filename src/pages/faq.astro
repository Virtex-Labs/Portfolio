---
import { faqs } from "../data/faq.ts";
import Layout from "../layouts/BaseLayout.astro";
import Contact from "../components/Contact.astro";
import FAQ from "../components/FAQ/FAQ.astro";

const title = "VIRTEX LABS | Frequently Asked Questions";
const description = "Find answers to common questions about Virtex Labs' web design process, technical stack, pricing, timelines, and digital services.";
const canonical = "https://virtexlabs.com/faq";

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "dateModified": "2026-06-15",
  "mainEntity": faqs.map((faq) => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer,
    },
  })),
};
---

<Layout title={title} description={description} canonical={canonical}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    
    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
    <meta name="googlebot" content="index, follow" />
    <meta name="abstract" content="Virtex Labs FAQ. Answers to common questions regarding our premium web design, UI/UX architecture, custom web applications, pricing, and timelines." />
    <meta name="topic" content="Frequently Asked Questions" />
    <meta name="subject" content="Web Design and Development Services FAQ" />
    <meta name="publisher" content="Virtex Labs" />
    <meta property="article:modified_time" content="2026-06-15T00:00:00Z" />
  </Fragment>

  <FAQ />

  <Contact />
</Layout>

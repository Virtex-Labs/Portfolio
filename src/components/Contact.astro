---

---

<section
  id="contact-section"
  aria-label="Contact Virtex Labs"
  class="relative min-h-screen bg-[#050508] text-white flex flex-col justify-between px-6 sm:px-12 md:px-20 lg:px-32 py-16 lg:py-24 z-20 overflow-hidden"
>
  <div class="absolute inset-0 pointer-events-none z-0 overflow-hidden">
    <div
      class="absolute bottom-[-20%] right-[-10%] w-[60vw] h-[60vw] rounded-full opacity-20 filter blur-[120px]"
      style="background: radial-gradient(circle, rgba(159,55,148,0.4) 0%, transparent 70%);"
    >
    </div>
    <div
      class="absolute top-[20%] left-[-10%] w-[50vw] h-[50vw] rounded-full opacity-10 filter blur-[100px]"
      style="background: radial-gradient(circle, rgba(226,36,114,0.3) 0%, transparent 70%);"
    >
    </div>
  </div>

  <div
    class="relative z-10 grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8 items-start w-full my-auto"
  >
    <div
      class="lg:col-span-5 flex flex-col justify-between h-full space-y-10 lg:space-y-24"
    >
      <div id="contact-header" class="opacity-0 will-change-transform">
        <h2
          class="font-black text-[11vw] sm:text-5xl md:text-6xl lg:text-7xl tracking-tighter uppercase leading-[0.95] mb-4 sm:mb-8"
        >
          Let's create<br />something<br />
          <em
            class="not-italic text-transparent bg-clip-text bg-gradient-to-r from-[#e22472] via-[#9f3794] to-[#7e4199]"
          >
            legendary.
          </em>
        </h2>
      </div>

      <div
        id="contact-meta"
        class="space-y-8 opacity-0 will-change-transform translate-y-10"
      >
        <div>
          <p class="text-white/30 text-xs uppercase tracking-wider mb-2">
            Direct Channel
          </p>
          <a
            href="mailto:hello@virtexlabs.com"
            class="text-xl md:text-2xl font-medium tracking-tight hover:text-[#e22472] transition-colors relative inline-block group py-1 break-all sm:break-normal"
          >
            hello@virtexlabs.com
            <span
              class="absolute bottom-0 left-0 w-full h-px bg-white/20 origin-left scale-x-100 group-hover:scale-x-0 transition-transform duration-300"
            ></span>
            <span
              class="absolute bottom-0 left-0 w-full h-px bg-[#e22472] origin-right scale-x-0 group-hover:scale-x-100 transition-transform duration-300"
            ></span>
          </a>
        </div>

        <div class="flex flex-col sm:flex-row gap-8 sm:gap-16">
          <div>
            <p class="text-white/30 text-xs uppercase tracking-wider mb-3">
              Digital Presence
            </p>
            <ul class="space-y-2 text-sm font-medium">
              <li>
                <a href="#" class="hover:text-[#9f3794] transition-colors block"
                  >LinkedIn</a>
              </li>
              <li>
                <a href="#" class="hover:text-[#9f3794] transition-colors block"
                  >GitHub</a>
              </li>
              <li>
                <a href="#" class="hover:text-[#9f3794] transition-colors block"
                  >Instagram</a>
              </li>
            </ul>
          </div>
          <div>
            <p class="text-white/30 text-xs uppercase tracking-wider mb-3">
              Operations
            </p>
            <p class="text-sm font-medium text-white/80">
              Sri Lanka<br /><span class="text-white/40 font-light"
                >GMT +5:30</span>
            </p>
          </div>
        </div>
      </div>
    </div>

    <form
      id="contact-form"
      class="lg:col-span-7 w-full mt-4 lg:mt-0 space-y-8 md:space-y-10 opacity-0 will-change-transform translate-y-20"
    >
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-10">
        <div class="form-group relative w-full">
          <input
            type="text"
            id="name"
            required
            placeholder=" "
            class="form-input w-full bg-transparent border-b border-white/10 focus:border-white py-4 outline-none focus:outline-none focus:ring-0 transition-colors text-lg font-light tracking-wide z-10 relative"
          />
          <label
            for="name"
            class="form-label absolute left-0 top-4 text-white/40 text-lg font-light transition-all pointer-events-none origin-left"
            >Your Name</label
          >
          <div
            class="input-focus-line absolute bottom-0 left-0 h-px bg-gradient-to-r from-[#e22472] to-[#7e4199] w-full scale-x-0 origin-left transition-transform duration-500"
          >
          </div>
        </div>

        <div class="form-group relative w-full">
          <input
            type="email"
            id="email"
            required
            placeholder=" "
            class="form-input w-full bg-transparent border-b border-white/10 focus:border-white py-4 outline-none focus:outline-none focus:ring-0 transition-colors text-lg font-light tracking-wide z-10 relative"
          />
          <label
            for="email"
            class="form-label absolute left-0 top-4 text-white/40 text-lg font-light transition-all pointer-events-none origin-left"
            >Email Address</label
          >
          <div
            class="input-focus-line absolute bottom-0 left-0 h-px bg-gradient-to-r from-[#e22472] to-[#7e4199] w-full scale-x-0 origin-left transition-transform duration-500"
          >
          </div>
        </div>
      </div>

      <div class="space-y-4 pt-4">
        <p class="text-white/40 text-sm tracking-wide font-light">
          I'm looking for assistance with...
        </p>
        <div class="flex flex-wrap gap-2 sm:gap-3">
          {
            [
              "Web Design",
              "UI/UX Architecture",
              "Web Application",
              "Mobile App",
              "Other",
            ].map((tag) => (
              <button
                type="button"
                class="project-tag-btn px-4 sm:px-5 py-2 sm:py-2.5 rounded-full border border-white/10 bg-white/5 text-xs sm:text-sm font-medium hover:border-white/30 transition-all cursor-pointer select-none"
              >
                {tag}
              </button>
            ))
          }
        </div>
      </div>

      <div class="form-group relative w-full pt-4">
        <textarea
          id="message"
          required
          rows="4"
          placeholder=" "
          class="form-input w-full bg-transparent border-b border-white/10 focus:border-white py-4 outline-none focus:outline-none focus:ring-0 transition-colors text-lg font-light tracking-wide resize-none z-10 relative"
        ></textarea>
        <label
          for="message"
          class="form-label absolute left-0 top-8 text-white/40 text-lg font-light transition-all pointer-events-none origin-left"
          >Tell us about your project</label
        >
        <div
          class="input-focus-line absolute bottom-0 left-0 h-px bg-gradient-to-r from-[#e22472] to-[#7e4199] w-full scale-x-0 origin-left transition-transform duration-500"
        >
        </div>
      </div>

      <div class="pt-6 flex justify-end">
        <button
          type="submit"
          id="submit-btn"
          class="relative group w-full sm:w-auto px-10 py-4 sm:py-5 rounded-full overflow-hidden border border-white/20 bg-transparent flex items-center justify-center gap-4 transition-all duration-300 hover:border-white cursor-pointer shadow-lg"
        >
          <div
            class="absolute inset-0 bg-gradient-to-r from-[#e22472] via-[#9f3794] to-[#7e4199] scale-x-0 origin-right group-hover:scale-x-100 transition-transform duration-500 z-0"
            style="transition-timing-function: cubic-bezier(0.77, 0, 0.175, 1);"
          >
          </div>

          <span
            class="relative z-10 text-sm sm:text-base font-bold uppercase tracking-wider transition-colors duration-300"
          >
            Send Blueprint
          </span>

          <svg
            class="relative z-10 w-4 h-4 transform rotate-[45deg] transition-transform duration-500 group-hover:-rotate-[45deg]"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75"></path>
          </svg>
        </button>
      </div>
    </form>
  </div>

  <div
    id="contact-footer"
    class="relative z-10 pt-10 sm:pt-16 mt-16 sm:mt-auto border-t border-white/5 w-full flex flex-col sm:flex-row justify-between items-center text-center sm:text-left text-[10px] sm:text-xs text-white/30 font-medium tracking-wider uppercase gap-4 opacity-0"
  >
    <p>&copy; {new Date().getFullYear()} VIRTEX LABS. ALL RIGHTS RESERVED.</p>
    <p class="tracking-widest">CRAFTING FLUID CODE & SHARP PRODUCTS</p>
  </div>
</section>

<style>
  .form-input:focus ~ .form-label,
  .form-input:not(:placeholder-shown) ~ .form-label {
    transform: translateY(-24px) scale(0.75);
    color: #e22472;
  }

  textarea.form-input:focus ~ .form-label,
  textarea.form-input:not(:placeholder-shown) ~ .form-label {
    transform: translateY(-32px) scale(0.75);
  }

  .form-input:focus ~ .input-focus-line {
    transform: scaleX(1);
  }

  .project-tag-btn.is-selected {
    background: white !important;
    color: #050508 !important;
    border-color: white !important;
    box-shadow: 0 10px 25px rgba(255, 255, 255, 0.15);
  }

  .form-input:focus {
    outline: none !important;
    box-shadow: none !important;
    -webkit-box-shadow: none !important;
  }
</style>

<script>
  import gsap from "gsap";
  import ScrollTrigger from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  let ctx: gsap.Context | undefined;

  function initContact() {
    ctx?.revert();

    const section = document.getElementById("contact-section");
    const header = document.getElementById("contact-header");
    const meta = document.getElementById("contact-meta");
    const form = document.getElementById("contact-form");
    const footer = document.getElementById("contact-footer");

    if (!section || !header || !meta || !form || !footer) return;

    ctx = gsap.context(() => {
      const masterTl = gsap.timeline({
        scrollTrigger: {
          trigger: section,
          start: "top 75%",
          end: "top 25%",
          toggleActions: "play none none reverse",
        },
      });

      masterTl
        .fromTo(
          header,
          { opacity: 0, y: 50 },
          { opacity: 1, y: 0, duration: 1, ease: "power4.out" },
        )
        .fromTo(
          meta,
          { opacity: 0, y: 30 },
          { opacity: 1, y: 0, duration: 0.8, ease: "power3.out" },
          "-=0.7",
        )
        .fromTo(
          form,
          { opacity: 0, y: 40 },
          { opacity: 1, y: 0, duration: 1, ease: "power3.out" },
          "-=0.8",
        )
        .fromTo(footer, { opacity: 0 }, { opacity: 1, duration: 1 }, "-=0.5");

      const tagButtons = document.querySelectorAll(".project-tag-btn");
      tagButtons.forEach((btn) => {
        btn.addEventListener("click", () => {
          btn.classList.toggle("is-selected");
        });
      });
    }, section);
  }

  document.addEventListener("astro:page-load", initContact);
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initContact);
  } else {
    initContact();
  }
</script>

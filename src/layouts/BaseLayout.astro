---
import Navbar from "../components/Navbar.astro";
import Welcome from "../components/Welcome.astro";
import LandscapeWarning from "../components/LandscapeWarning.astro";
import CookieBanner from "../components/CookieBanner.astro";
import Toaster from "../components/Toaster.astro";
import PageTransition from "../providers/PageTransition.astro";
import PageLayout from "./PageLayout.astro";
import "../styles/global.css";

const { title, description, canonical, ogImage, forceSolidNav = false, noHideNav = false } = Astro.props;
---

<PageLayout title={title} description={description} canonical={canonical} ogImage={ogImage}>
  <Fragment slot="head">
    <script is:inline>
      if ("scrollRestoration" in history) {
        history.scrollRestoration = "manual";
      }
      window.scrollTo(0, 0);
      window.addEventListener("pageshow", () => {
        window.scrollTo(0, 0);
      });

      if (typeof navigator !== "undefined" && "modelContext" in navigator) {
        // @ts-ignore
        navigator.modelContext.provideContext({
          tools: [
            {
              name: "get_portfolio_info",
              description: "Returns basic information about this portfolio",
              inputSchema: { type: "object", properties: {} },
              execute: async () => {
                return {
                  content: [
                    {
                      type: "text",
                      text: "This is the portfolio of Virtex Labs.",
                    },
                  ],
                };
              },
            },
          ],
        });
      }
    </script>
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@graph": [

          {
            "@type": "WebSite",
            "@id": "https://virtexlabs.com/#website",
            name: "Virtex Labs",
            url: "https://virtexlabs.com",
            publisher: { "@id": "https://virtexlabs.com/#organization" },
          },
          {
            "@type": "WebPage",
            "@id": "https://virtexlabs.com/#webpage",
            url: "https://virtexlabs.com",
            name: "Virtex Labs Portfolio",
            isPartOf: { "@id": "https://virtexlabs.com/#website" },
            about: { "@id": "https://virtexlabs.com/#organization" },
            datePublished: "2024-01-01T00:00:00Z",
            dateModified: new Date().toISOString(),
            author: { "@id": "https://virtexlabs.com/#organization" },
          },
        ],
      })}
    />
    <slot name="head" />
  </Fragment>

  <LandscapeWarning />
  <Welcome />
  <Navbar forceSolid={forceSolidNav} noHide={noHideNav} />

  <main>
    <slot />
  </main>
  <CookieBanner />
  <Toaster />
  <PageTransition />

  <script>
    import "../scripts/animations.ts";
  </script>
</PageLayout>

---
import { faqs } from "../data/faq.ts";
import Layout from "../layouts/BaseLayout.astro";
import Contact from "../components/Contact.astro";
import mannequin from "../assets/images/mannequin.png";
---

<Layout title="VIRTEX LABS | FAQ">
  <section
    id="faq-page"
    class="relative overflow-hidden bg-white text-[#050505]"
    aria-label="Frequently Asked Questions"
  >
    <section
      id="faq-desktop"
      class="faq-desktop-scene hidden lg:block relative min-h-[560vh] overflow-hidden bg-[#fcf2f6]"
      aria-label="Frequently Asked Questions desktop"
    >
      <div
        class="faq-desktop-pin relative flex min-h-screen w-full items-center justify-center overflow-hidden px-10 py-20"
      >
        <div class="faq-gradient-wash absolute inset-0 z-0"></div>

        <header
          class="faq-title-wrap pointer-events-none absolute left-1/2 top-1/2 z-30 w-full max-w-[92vw] -translate-x-1/2 -translate-y-1/2 text-center"
        >
          <p
            class="faq-kicker mb-5 text-xs font-black uppercase tracking-[0.45em] text-[#e22472]"
          >
            FAQ topics
          </p>
          <h1
            class="faq-title mx-auto max-w-7xl text-[clamp(5.25rem,10.4vw,13rem)] font-black leading-[0.82] tracking-tight text-[#050505]"
          >
            Frequently Asked Questions
          </h1>
        </header>

        <div
          class="faq-mannequin absolute bottom-[-8vh] left-1/2 z-20 w-[min(40vw,560px)] -translate-x-1/2 pointer-events-none"
          aria-hidden="true"
        >
          <img
            src={mannequin.src}
            alt=""
            class="h-auto w-full max-w-none grayscale"
            loading="eager"
          />
        </div>

        <div
          class="faq-list-wrap absolute bottom-[8vh] right-[5vw] z-10 w-[min(54vw,880px)]"
        >
          <div class="faq-list-header mb-5 flex items-end justify-between gap-6">
            <p
              class="text-xs font-black uppercase tracking-[0.35em] text-[#9f3794]/80"
            >
              FAQ topics
            </p>
            <span class="h-px flex-1 bg-[#050505]/10"></span>
          </div>

          <div class="faq-items space-y-3">
            {
              faqs.map((faq, index) => (
                <details
                  class="faq-item group border-b border-[#050505]/10 bg-white/35 px-5 py-4 backdrop-blur-sm transition-colors duration-300 open:bg-white/75"
                  data-index={index}
                >
                  <summary class="flex cursor-pointer list-none items-start justify-between gap-6">
                    <span class="flex gap-5">
                      <span class="pt-1 text-xs font-black text-[#e22472]/70">
                        {String(index + 1).padStart(2, "0")}
                      </span>
                      <span class="text-xl font-black leading-tight tracking-tight text-[#050505]">
                        {faq.question}
                      </span>
                    </span>
                    <span
                      class="faq-plus relative mt-1 grid h-7 w-7 shrink-0 place-items-center rounded-full border border-[#050505]/15 text-[#050505] transition-transform duration-300 group-open:rotate-45"
                      aria-hidden="true"
                    >
                      +
                    </span>
                  </summary>

                  <div class="grid grid-rows-[0fr] transition-[grid-template-rows] duration-300 group-open:grid-rows-[1fr]">
                    <div class="overflow-hidden">
                      <p class="max-w-3xl pb-2 pl-[3.25rem] pt-4 text-base leading-relaxed text-[#050505]/65">
                        {faq.answer}
                      </p>
                    </div>
                  </div>
                </details>
              ))
            }
          </div>
        </div>

        <aside
          class="faq-more-info pointer-events-auto absolute left-[7vw] top-1/2 z-20 w-[min(34vw,520px)] -translate-y-1/2"
          aria-label="More information"
        >
          <p
            class="mb-5 text-xs font-black uppercase tracking-[0.42em] text-[#e22472]"
          >
            Still curious?
          </p>
          <h2
            class="text-[clamp(4rem,7.4vw,9rem)] font-black leading-[0.82] tracking-tight text-[#050505]"
          >
            Need more info?
          </h2>
          <a
            href="mailto:hello@virtexlabs.com"
            class="mt-10 inline-flex border-b border-[#050505]/25 pb-2 text-[clamp(1.1rem,1.5vw,1.5rem)] font-bold tracking-tight text-[#050505] transition-colors hover:text-[#e22472]"
          >
            hello@virtexlabs.com
          </a>
        </aside>
      </div>
    </section>

    <section
      id="faq-mobile"
      class="block lg:hidden bg-[#fcf2f6]"
      aria-label="FAQ mobile"
    >
      <div class="mobile-faq-content relative px-5 pb-20 pt-[28vh]">
        <header class="mobile-faq-title sticky top-[16vh] z-30 mb-16">
          <p
            class="mobile-faq-kicker mb-5 text-[0.68rem] font-black uppercase tracking-[0.36em] text-[#e22472]"
          >
            FAQ topics
          </p>
          <h1
            class="text-[clamp(5.2rem,28vw,9.5rem)] font-black leading-[0.76] tracking-tight text-[#050505]"
          >
            FAQ
          </h1>
        </header>

        <div class="mobile-list relative z-10 mt-[34vh] space-y-3">
          {
            faqs.map((faq, index) => (
              <details class="mobile-faq-item group border-b border-[#050505]/10 bg-white/45 px-4 py-4 backdrop-blur-sm open:bg-white/80">
                <summary class="flex cursor-pointer list-none items-start justify-between gap-4">
                  <span class="flex gap-3">
                    <span class="pt-1 text-[0.68rem] font-black text-[#9f3794]/70">
                      {String(index + 1).padStart(2, "0")}
                    </span>
                    <span class="text-[1.05rem] font-black leading-tight tracking-tight text-[#050505]">
                      {faq.question}
                    </span>
                  </span>
                  <span
                    class="grid h-6 w-6 shrink-0 place-items-center rounded-full border border-[#050505]/15 text-sm font-black transition-transform duration-300 group-open:rotate-45"
                    aria-hidden="true"
                  >
                    +
                  </span>
                </summary>
                <div class="grid grid-rows-[0fr] transition-[grid-template-rows] duration-300 group-open:grid-rows-[1fr]">
                  <div class="overflow-hidden">
                    <p class="pb-2 pl-9 pt-4 text-[0.94rem] leading-relaxed text-[#050505]/65">
                      {faq.answer}
                    </p>
                  </div>
                </div>
              </details>
            ))
          }
        </div>
      </div>

      <section
        class="mobile-more-scene relative min-h-[280vh] overflow-hidden bg-[#fcf2f6]"
        aria-label="More information"
      >
        <div
          class="mobile-more-pin relative flex min-h-screen flex-col items-center justify-center px-5 text-center"
        >
          <h2
            class="mobile-more-words flex flex-wrap items-center justify-center gap-x-[0.22em] gap-y-2 text-[clamp(3.2rem,18vw,6.6rem)] font-black leading-[0.85] tracking-tight text-[#050505]"
            aria-label="Need more info?"
          >
            <span class="mobile-word">Need</span>
            <span class="mobile-word text-gradient">more</span>
            <span class="mobile-word">info?</span>
          </h2>

          <a
            href="mailto:hello@virtexlabs.com"
            class="mobile-email absolute left-1/2 top-1/2 -translate-x-1/2 translate-y-16 whitespace-nowrap border-b border-[#050505]/20 pb-2 text-[1rem] font-black tracking-tight text-[#050505]"
          >
            hello@virtexlabs.com
          </a>
        </div>
      </section>
    </section>
  </section>

  <Contact />

  <style>
    .faq-gradient-wash {
      background:
        radial-gradient(circle at 15% 20%, rgba(226, 36, 114, 0.24), transparent 34%),
        radial-gradient(circle at 85% 82%, rgba(126, 65, 153, 0.22), transparent 32%),
        linear-gradient(180deg, #ffffff 0%, #fcf2f6 62%, #fcf2f6 100%);
    }

    .faq-title,
    .faq-more-info h2,
    .mobile-faq-title h1,
    .mobile-more-words {
      text-wrap: balance;
    }

    .faq-title-wrap,
    .faq-mannequin,
    .faq-list-wrap,
    .faq-item,
    .faq-more-info,
    .mobile-faq-title,
    .mobile-faq-item,
    .mobile-word,
    .mobile-email {
      will-change: transform, opacity;
    }

    .faq-item summary::-webkit-details-marker,
    .mobile-faq-item summary::-webkit-details-marker {
      display: none;
    }

    .faq-more-info {
      opacity: 0;
      transform: translate3d(-38vw, -50%, 0);
    }

    .faq-list-wrap {
      opacity: 0;
      transform: translate3d(0, 72vh, 0);
    }

    .faq-mannequin {
      opacity: 0;
      filter: grayscale(1) contrast(1.04);
      transform: translate3d(-50%, 22vh, 0);
    }

    .mobile-word,
    .mobile-email {
      opacity: 0;
    }

    .mobile-word {
      display: inline-block;
      transform: translate3d(4rem, 0, 0);
    }

    .mobile-email {
      transform: translate3d(-50%, 3rem, 0);
    }

    @media (max-width: 420px) {
      .mobile-more-words {
        gap-row: 0.15em;
      }

      .mobile-email {
        font-size: 0.92rem;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .faq-title-wrap,
      .faq-mannequin,
      .faq-list-wrap,
      .faq-item,
      .faq-more-info,
      .mobile-faq-title,
      .mobile-faq-item,
      .mobile-word,
      .mobile-email {
        opacity: 1 !important;
        transform: none !important;
      }

      .faq-more-info {
        position: absolute;
        left: 7vw;
        top: 50%;
        transform: translateY(-50%) !important;
      }

      .mobile-email {
        transform: translate(-50%, 3rem) !important;
      }
    }
  </style>

  <script>
    import gsap from "gsap";
    import ScrollTrigger from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    let mm: gsap.MatchMedia | undefined;

    function initFaq() {
      mm?.revert();
      mm = gsap.matchMedia();

      mm.add("(prefers-reduced-motion: reduce)", () => {
        gsap.set(
          [
            ".faq-title-wrap",
            ".faq-mannequin",
            ".faq-list-wrap",
            ".faq-item",
            ".faq-more-info",
            ".mobile-faq-title",
            ".mobile-faq-item",
            ".mobile-word",
            ".mobile-email",
          ],
          { clearProps: "all", autoAlpha: 1 },
        );
      });

      mm.add("(min-width: 1024px) and (prefers-reduced-motion: no-preference)", () => {
        const scene = document.querySelector("#faq-desktop");
        const pin = document.querySelector(".faq-desktop-pin");
        if (!scene || !pin) return;

        const items = gsap.utils.toArray<HTMLElement>(".faq-item", scene);
        const reversedItems = [...items].reverse();

        gsap.set(".faq-title-wrap", { yPercent: -50, scale: 1 });
        gsap.set(".faq-mannequin", { xPercent: -50, y: "22vh", x: 0, autoAlpha: 0 });
        gsap.set(".faq-list-wrap", { y: "72vh", x: 0, autoAlpha: 0 });
        gsap.set(items, { x: 0, y: 42, autoAlpha: 0 });
        gsap.set(".faq-more-info", { x: "-38vw", yPercent: -50, autoAlpha: 0 });

        const tl = gsap.timeline({
          scrollTrigger: {
            trigger: scene,
            start: "top top",
            end: "bottom bottom",
            scrub: 1.15,
            pin,
            anticipatePin: 1,
          },
        });

        tl.to(".faq-mannequin", {
          autoAlpha: 0.7,
          y: 0,
          duration: 0.9,
          ease: "power3.out",
        })
          .to(
            ".faq-title-wrap",
            {
              y: "-35vh",
              scale: 0.44,
              duration: 1.15,
              ease: "power2.inOut",
            },
            "<0.12",
          )
          .to(
            ".faq-mannequin",
            {
              x: "-29vw",
              y: "2vh",
              duration: 1.2,
              ease: "power2.inOut",
            },
            "<0.06",
          )
          .to(
            ".faq-list-wrap",
            {
              autoAlpha: 1,
              y: 0,
              duration: 1.05,
              ease: "power3.out",
            },
            "<0.22",
          )
          .to(
            items,
            {
              autoAlpha: 1,
              y: 0,
              duration: 0.7,
              stagger: 0.045,
              ease: "power3.out",
            },
            "<0.18",
          )
          .to({}, { duration: 1.45 })
          .to(
            reversedItems,
            {
              x: "62vw",
              autoAlpha: 0,
              duration: 0.82,
              stagger: 0.055,
              ease: "power3.inOut",
            },
            "desktopOutro",
          )
          .to(
            ".faq-list-wrap",
            {
              x: "12vw",
              duration: 1.25,
              ease: "power2.inOut",
            },
            "desktopOutro",
          )
          .to(
            ".faq-mannequin",
            {
              x: "30vw",
              autoAlpha: 0.62,
              duration: 1.35,
              ease: "power2.inOut",
            },
            "desktopOutro",
          )
          .to(
            ".faq-more-info",
            {
              x: 0,
              autoAlpha: 1,
              duration: 1.05,
              ease: "power3.out",
            },
            "desktopOutro+=0.08",
          )
          .to({}, { duration: 0.7 });
      });

      mm.add("(max-width: 1023px) and (prefers-reduced-motion: no-preference)", () => {
        const mobile = document.querySelector("#faq-mobile");
        const moreScene = document.querySelector(".mobile-more-scene");
        const morePin = document.querySelector(".mobile-more-pin");
        if (!mobile || !moreScene || !morePin) return;

        const mobileItems = gsap.utils.toArray<HTMLElement>(".mobile-faq-item", mobile);
        const words = gsap.utils.toArray<HTMLElement>(".mobile-word", mobile);

        gsap.set(".mobile-faq-title", { y: 0, autoAlpha: 1 });
        gsap.set(mobileItems, { y: 48, autoAlpha: 0 });
        gsap.set(words, { x: 76, autoAlpha: 0 });
        gsap.set(".mobile-email", { y: 48, autoAlpha: 0 });

        gsap.to(".mobile-faq-title", {
          y: -28,
          ease: "none",
          scrollTrigger: {
            trigger: ".mobile-list",
            start: "top 82%",
            end: "top 38%",
            scrub: true,
          },
        });

        mobileItems.forEach((item, index) => {
          gsap.to(item, {
            y: 0,
            autoAlpha: 1,
            duration: 0.78,
            ease: "power3.out",
            scrollTrigger: {
              trigger: item,
              start: "top 88%",
              toggleActions: "play none none reverse",
            },
            delay: (index % 3) * 0.025,
          });
        });

        const wordTl = gsap.timeline({
          scrollTrigger: {
            trigger: moreScene,
            start: "top top",
            end: "bottom bottom",
            scrub: 1,
            pin: morePin,
            anticipatePin: 1,
          },
        });

        words.forEach((word) => {
          wordTl
            .to(word, {
              x: 0,
              autoAlpha: 1,
              duration: 0.55,
              ease: "power3.out",
            })
            .to(word, {
              x: 72,
              autoAlpha: 0,
              duration: 0.48,
              ease: "power2.in",
            }, "+=0.08");
        });

        wordTl
          .to(".mobile-email", {
            y: 0,
            autoAlpha: 1,
            duration: 0.78,
            ease: "power3.out",
          })
          .to({}, { duration: 0.6 });
      });

      ScrollTrigger.refresh();
    }

    document.addEventListener("astro:page-load", initFaq);
    document.addEventListener("astro:before-swap", () => mm?.revert());

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initFaq, { once: true });
    } else {
      initFaq();
    }
  </script>
</Layout>

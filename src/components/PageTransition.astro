<script>
  import gsap from "gsap";

  function getPathLength(selector) {
    const path = document.querySelector(selector);
    return path ? path.getTotalLength() : 0;
  }

  function animateTransitionIn() {
    return new Promise((resolve) => {
      const len1 = getPathLength("#transition-path-1");
      const len2 = getPathLength("#transition-path-2");

      gsap.set("#transition-path-1", {
        strokeDasharray: len1,
        strokeDashoffset: len1,
      });
      gsap.set("#transition-path-2", {
        strokeDasharray: len2,
        strokeDashoffset: len2,
      });

      const tl = gsap.timeline({ onComplete: resolve });

      tl.to("#transition-path-1", {
        strokeDashoffset: 0,
        duration: 1,
        ease: "power3.inOut",
      }).to(
        "#transition-path-2",
        {
          strokeDashoffset: 0,
          duration: 1,
          ease: "power3.inOut",
        },
        "-=0.6",
      );
    });
  }

  function animateTransitionOut() {
    const tl = gsap.timeline();

    tl.to("#transition-path-2", {
      strokeDashoffset: "-100%",
      duration: 1,
      ease: "power3.inOut",
    }).to(
      "#transition-path-1",
      {
        strokeDashoffset: "-100%",
        duration: 1,
        ease: "power3.inOut",
      },
      "-=0.6",
    );
  }

  document.addEventListener("astro:before-preparation", (event) => {
    const ev = event as any;
    const originalLoader = ev.loader;
    ev.loader = async function () {
      await animateTransitionIn();
      await originalLoader();
    };
  });

  document.addEventListener("astro:after-swap", () => {
    animateTransitionOut();
  });
</script>

---
import { site } from "../data/site";

export interface Props {
  forceSolid?: boolean;
  noHide?: boolean;
}

const { forceSolid = false, noHide = false } = Astro.props;
const allNavItems = [...site.nav_left, ...site.nav_right];
const isHomepage =
  Astro.url.pathname === "/" || Astro.url.pathname === "/index.html";
const brandHref = isHomepage ? "#" : "/";
---

<header
  id="site-nav"
  aria-label="Site navigation"
  data-is-homepage={isHomepage.toString()}
  data-force-solid={forceSolid.toString()}
  data-no-hide={noHide.toString()}
  class={`fixed inset-x-0 top-0 z-[100] transition-colors duration-500 opacity-0 ${forceSolid ? "bg-white" : "bg-transparent"}`}
>
  <nav
    class={`mx-auto h-[100px] w-full px-6 lg:px-20 relative z-20 flex lg:grid lg:grid-cols-3 items-center ${
      isHomepage ? "justify-between" : "justify-center lg:justify-between"
    }`}
  >
    {
      isHomepage && (
        <ul class="hidden lg:flex h-full w-full items-center justify-between gap-1 list-none p-0 m-0">
          {site.nav_left.map((item) => (
            <li class="nav-item nav-left-item flex h-full">
              <a
                href={item.href}
                class="group relative flex h-full items-center px-4 text-lg font-[450] tracking-wide no-underline overflow-hidden"
              >
                <span class="relative block h-[1.3em] overflow-hidden">
                  <span class="block transition-transform duration-300 ease-out group-hover:-translate-y-full text-current">
                    {item.label}
                  </span>
                  <span class="absolute top-full left-0 block transition-transform duration-300 ease-out group-hover:-translate-y-full bg-[#e22472] bg-clip-text text-transparent font-semibold">
                    {item.label}
                  </span>
                </span>
                <span class="absolute top-0 left-0 h-[3px] w-full origin-center scale-x-0 bg-gradient-to-r from-[#9f3794] via-[#e22472] to-[#9f3794] transition-transform duration-300 ease-out group-hover:scale-x-100" />
              </a>
            </li>
          ))}
        </ul>
      )
    }

    <div
      class="nav-brand flex h-full items-center justify-center lg:col-start-2"
      aria-label="Home"
    >
      <a href={brandHref} class="flex items-center no-underline relative z-50">
        <slot name="brand">
          <img
            src="/wordmark.svg"
            alt={site.name}
            width="200"
            height="80"
            class="h-20 lg:h-24 w-auto object-contain transition-[filter,transform] duration-300 opacity-0"
            id="nav-logo-img"
            fetchpriority="high"
            loading="eager"
          />
        </slot>
      </a>
    </div>

    {
      isHomepage && (
        <div class="hidden lg:flex h-full items-center justify-end gap-1">
          <ul class="flex h-full w-full items-center justify-between gap-1 list-none p-0 m-0">
            {site.nav_right.map((item) => (
              <li class="nav-item nav-right-item flex h-full">
                <a
                  href={item.href}
                  class="group relative flex h-full items-center px-4 text-lg font-[450] tracking-wide no-underline overflow-hidden"
                >
                  <span class="relative block h-[1.3em] overflow-hidden">
                    <span class="block transition-transform duration-300 ease-out group-hover:-translate-y-full text-current">
                      {item.label}
                    </span>
                    <span class="absolute top-full left-0 block transition-transform duration-300 ease-out group-hover:-translate-y-full bg-[#e22472] bg-clip-text text-transparent font-semibold">
                      {item.label}
                    </span>
                  </span>
                  <span class="absolute top-0 left-0 h-[3px] w-full origin-center scale-x-0 bg-gradient-to-r from-[#9f3794] via-[#e22472] to-[#9f3794] transition-transform duration-300 ease-out group-hover:scale-x-100" />
                </a>
              </li>
            ))}
          </ul>
        </div>
      )
    }

    {
      isHomepage && (
        <button
          id="mobile-menu-toggle"
          class="lg:hidden relative z-50 flex flex-col justify-center items-center w-12 h-12 gap-1.5 focus:outline-none opacity-0"
          aria-label="Toggle Menu"
        >
          <span class="hamburger-line w-8 h-[2px] bg-current block transition-all duration-300 origin-center" />
          <span class="hamburger-line w-8 h-[2px] bg-current block transition-all duration-300 origin-center" />
        </button>
      )
    }
  </nav>
</header>

{
  isHomepage && (
    <div
      id="mobile-overlay"
      class="fixed inset-0 bg-white z-50 flex flex-col items-center justify-center pointer-events-none"
    >
      <div class="absolute inset-0 pointer-events-none overflow-hidden z-0" />

      <ul class="flex flex-col items-center gap-8 z-10 w-full px-6 text-center">
        {allNavItems.map((item) => (
          <li class="mobile-nav-link-wrap overflow-hidden w-full">
            <a
              href={item.href}
              class="mobile-nav-link block text-4xl sm:text-5xl font-black uppercase tracking-widest text-zinc-900 hover:text-[#e22472] transition-colors translate-y-[120%] will-change-transform"
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>

      <div class="mobile-nav-footer absolute bottom-10 w-full text-center opacity-0">
        <p class="text-zinc-500 text-xs tracking-[0.2em] font-medium uppercase">
          Virtex Labs &copy; {new Date().getFullYear()}
        </p>
      </div>
    </div>
  )
}

<style>
  #site-nav {
    color: black;
  }
  #site-nav[data-is-homepage="true"].bg-transparent {
    color: white;
  }
  #site-nav[data-is-homepage="true"].bg-transparent #nav-logo-img {
    filter: brightness(0) invert(1);
  }
  @media (min-width: 1024px) {
    #site-nav[data-is-homepage="true"].bg-transparent .nav-brand a:hover #nav-logo-img {
      filter: brightness(0) invert(1) drop-shadow(0 0 8px rgb(238, 0, 255))
        drop-shadow(0 0 24px rgba(255, 255, 255, 0.6))
        drop-shadow(0 0 48px rgba(255, 255, 255, 0.2));
    }
  }
  @media (prefers-reduced-motion: reduce) {
    #site-nav {
      height: 10vh;
    }
    #site-nav,
    .nav-item,
    .mobile-nav-link,
    #mobile-overlay,
    #nav-logo-img,
    #mobile-menu-toggle {
      opacity: 1 !important;
      transform: none !important;
    }
  }
  #mobile-menu-toggle.is-open .hamburger-line:nth-child(1) {
    transform: translateY(4px) rotate(45deg);
    background-color: #050508 !important;
  }
  #mobile-menu-toggle.is-open .hamburger-line:nth-child(2) {
    transform: translateY(-4px) rotate(-45deg);
    background-color: #050508 !important;
  }
</style>

<script>
  import gsap from "gsap";
  import ScrollTrigger from "gsap/ScrollTrigger";
  import { isMobile } from "get-browser";

  gsap.registerPlugin(ScrollTrigger);

  function initNav() {
    const header = document.getElementById("site-nav");
    const leftItems = Array.from(document.querySelectorAll(".nav-left-item"));
    const rightItems = Array.from(document.querySelectorAll(".nav-right-item"));
    const brand = document.querySelector(".nav-brand");
    const logoImg = document.getElementById("nav-logo-img");
    const menuToggle = document.getElementById("mobile-menu-toggle");
    const mobileOverlay = document.getElementById("mobile-overlay");
    const mobileLinks = gsap.utils.toArray(".mobile-nav-link");
    const mobileFooter = document.querySelector(".mobile-nav-footer");

    const LOGO_EVENT = "vl-logo-complete";
    const FLY_EVENT = "vl-logo-flying";

    const userAgent = navigator.userAgent || "";
    const mobileDevice = isMobile({ userAgent });

    if (!header) return;
    const forceSolid = header.getAttribute("data-force-solid") === "true";
    const noHide = header.getAttribute("data-no-hide") === "true";

    const prefersReduced = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;

    const isHomepage =
      window.location.pathname === "/" ||
      window.location.pathname === "/index.html";

    if (!prefersReduced) {
      gsap.set(header, { opacity: 0 });
      gsap.set(brand, { opacity: 0 });
      gsap.set(logoImg, { opacity: 0 });
      if (menuToggle) gsap.set(menuToggle, { opacity: 0 });

      if (!mobileDevice) {
        gsap.set(leftItems, { opacity: 0, x: 40 });
        gsap.set(rightItems, { opacity: 0, x: -40 });
      }
    }

    function startNavAnimation() {
      const tl = gsap.timeline({
        defaults: { ease: "power3.out" },
      });

      tl.to(header, { opacity: 1, duration: 0.5 });
      tl.to(brand, { opacity: 1, duration: 0.1 }, "<");

      if (!mobileDevice && isHomepage) {
        tl.to(
          leftItems,
          { opacity: 1, x: 0, duration: 0.45, stagger: 0.06 },
          "-=0.2",
        ).to(
          rightItems,
          {
            opacity: 1,
            x: 0,
            duration: 0.45,
            stagger: { each: 0.06, from: "start" },
          },
          "<",
        );
      }

      if (menuToggle) {
        tl.to(
          menuToggle,
          { opacity: 1, duration: 0.3 },
          mobileDevice ? "-=0.1" : "-=0.3",
        );
      }

      tl.to(logoImg, { opacity: 1, duration: 0.2 }, 0.7);
    }

    if (!prefersReduced) {
      if (!isHomepage || window.__vlLogoDone === true) {
        startNavAnimation();
      } else {
        window.addEventListener(
          FLY_EVENT,
          () => {
            startNavAnimation();
          },
          { once: true },
        );

        setTimeout(() => {
          if (window.__vlLogoDone !== true) startNavAnimation();
        }, 4500);
      }
    }

    let isMenuOpen = false;
    let menuAnimation;

    if (menuToggle && mobileOverlay) {
      gsap.set(mobileOverlay, { yPercent: -100 });

      menuAnimation = gsap
        .timeline({ paused: true, defaults: { ease: "power2.out" } })
        .to(mobileOverlay, {
          yPercent: 0,
          pointerEvents: "auto",
          duration: 0.45,
        })
        .to(
          mobileLinks,
          { y: 0, duration: 0.4, stagger: 0.04, ease: "power2.out" },
          "-=0.2",
        )
        .to(mobileFooter, { opacity: 1, duration: 0.3 }, "-=0.2");

      menuToggle.addEventListener("click", () => {
        isMenuOpen = !isMenuOpen;

        if (isMenuOpen) {
          menuToggle.classList.add("is-open");
          if (window.__lenis) window.__lenis.stop();
          header.classList.add("bg-white");
          header.classList.remove("bg-transparent");
          menuAnimation.timeScale(1).play();
        } else {
          menuToggle.classList.remove("is-open");
          if (window.__lenis) window.__lenis.start();
          const isHomepage = header.getAttribute("data-is-homepage") === "true";
          const threshold = isHomepage ? window.innerHeight - 100 : 50;
          if (window.scrollY < threshold && !forceSolid) {
            header.classList.remove("bg-white");
            header.classList.add("bg-transparent");
          }
          menuAnimation.timeScale(1.5).reverse();
        }
      });

      mobileLinks.forEach((link) => {
        link.addEventListener("click", () => {
          if (isMenuOpen) menuToggle.click();
        });
      });
    }

    let isNavHidden = false;

    if (window.__vlNavScrollTrigger) {
      window.__vlNavScrollTrigger.kill();
    }

    window.__vlNavScrollTrigger = ScrollTrigger.create({
      start: "top top",
      end: "max",
      onUpdate: (self) => {
        if (ScrollTrigger.isRefreshing) return;
        if (isMenuOpen) return;

        const currentY = window.scrollY;
        const isHomepage = header.getAttribute("data-is-homepage") === "true";
        const threshold = isHomepage ? window.innerHeight - 100 : 50;

        if (currentY > threshold || forceSolid) {
          header.classList.add("bg-white");
          header.classList.remove("bg-transparent");
        } else {
          header.classList.remove("bg-white");
          header.classList.add("bg-transparent");
        }

        let forceHide = false;
        if (header.hasAttribute("data-force-hide-nav")) forceHide = true;

        document.querySelectorAll("[data-hide-nav]").forEach((section) => {
          const rect = section.getBoundingClientRect();
          if (rect.top <= header.offsetHeight && rect.bottom > 0)
            forceHide = true;
        });

        if (forceHide) {
          if (!isNavHidden) {
            gsap.to(header, {
              yPercent: -100,
              duration: 1,
              ease: "power2.inOut",
              overwrite: "auto",
            });
            isNavHidden = true;
          }
        } else if (!noHide) {
          if (self.direction === 1 && !isNavHidden && currentY > 100) {
            gsap.to(header, {
              yPercent: -100,
              duration: 1,
              ease: "power2.inOut",
              overwrite: "auto",
            });
            isNavHidden = true;
          } else if (self.direction === -1 && isNavHidden) {
            gsap.to(header, {
              yPercent: 0,
              duration: 1,
              ease: "power3.out",
              overwrite: "auto",
            });
            isNavHidden = false;
          }
        } else if (noHide && isNavHidden) {
          gsap.to(header, {
            yPercent: 0,
            duration: 1,
            ease: "power3.out",
            overwrite: "auto",
          });
          isNavHidden = false;
        }
      },
    });
  }

  document.addEventListener("astro:page-load", initNav);
</script>

---
import { site } from "../data/site";
---

<section
  id="work"
  aria-label="Selected Work"
  class="port-panel section-dark relative z-20 flex min-h-screen w-full flex-col justify-center overflow-hidden px-6 py-20 sm:px-10 md:px-20 lg:px-32"
>
  <div
    class="pointer-events-none absolute left-1/3 top-0 h-[600px] w-[600px] rounded-full bg-[#8B3FAF] opacity-[0.05] blur-[150px]"
  >
  </div>

  <div
    class="port-top relative z-10 mb-12 flex items-center justify-between gap-6"
  >
    <span
      class="port-reveal text-[0.7rem] font-semibold uppercase tracking-[0.3em] text-white/30"
    >
      Work
    </span>
    <span
      class="port-reveal text-[0.7rem] font-light tracking-widest text-white/20"
    >
      06
    </span>
  </div>

  <div class="relative z-10 mb-16 max-w-3xl">
    <h2
      class="m-0 font-sans text-[clamp(2.6rem,5vw,4.8rem)] font-black leading-[0.96] tracking-tight text-white"
    >
      <span class="port-line block overflow-hidden pb-[0.08em]">
        <span class="port-line-inner block">Selected</span>
      </span>
      <span class="port-line block overflow-hidden pb-[0.08em]">
        <span class="port-line-inner block">
          <em class="not-italic text-gradient">work.</em>
        </span>
      </span>
    </h2>
  </div>

  <div
    class="relative z-10 grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3"
  >
    {
      site.portfolio.map((project) => (
        <a
          href={project.href}
          class="port-card group relative block overflow-hidden rounded-2xl border border-white/[0.06] bg-white/[0.03] transition-all duration-500 hover:border-white/[0.12] hover:bg-white/[0.06]"
        >
          <div class="relative aspect-[4/3] overflow-hidden bg-gradient-to-br from-[#141414] to-[#1a1a1a]">
            <div class="absolute inset-0 bg-gradient-to-br from-[#4F5DB8]/20 via-[#8B3FAF]/10 to-[#E11D74]/20 opacity-60 transition-opacity duration-500 group-hover:opacity-100" />
            <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_50%,rgba(139,63,175,0.3),transparent_70%)]" />

            <span class="absolute left-4 top-4 rounded-full bg-white/10 px-3 py-1.5 text-[0.65rem] font-semibold uppercase tracking-widest text-white/70 backdrop-blur-sm">
              {project.label}
            </span>
          </div>

          <div class="p-6 lg:p-8">
            <h3 class="mb-2 text-lg font-bold tracking-tight text-white lg:text-xl">
              {project.title}
            </h3>
            <p class="text-[0.85rem] font-light leading-[1.7] text-white/45">
              {project.description}
            </p>
          </div>
        </a>
      ))
    }

    <a
      href="#contact"
      class="port-card group relative flex flex-col items-center justify-center overflow-hidden rounded-2xl border border-dashed border-white/[0.1] bg-transparent p-8 transition-all duration-500 hover:border-white/[0.25] hover:bg-white/[0.03] min-h-[320px]"
    >
      <div
        class="mb-6 flex h-16 w-16 items-center justify-center rounded-full border border-white/[0.1] transition-all duration-500 group-hover:border-white/[0.25] group-hover:bg-white/[0.05]"
      >
        <svg
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="text-white/40 transition-colors duration-500 group-hover:text-white/70"
        >
          <line x1="12" y1="5" x2="12" y2="19"></line>
          <line x1="5" y1="12" x2="19" y2="12"></line>
        </svg>
      </div>

      <p
        class="mb-4 text-center text-[1.1rem] font-semibold tracking-tight text-white/60 transition-colors duration-500 group-hover:text-white/90"
      >
        Your project could be here
      </p>
      <span
        class="text-[0.75rem] font-medium uppercase tracking-widest text-gradient"
      >
        Let's talk →
      </span>
    </a>
  </div>
</section>

<style>
  .port-line-inner {
    will-change: transform;
  }
  .port-reveal {
    will-change: transform, opacity;
  }
  .port-card {
    will-change: transform, opacity;
  }

  @media (prefers-reduced-motion: reduce) {
    .port-line-inner {
      transform: none !important;
    }
    .port-reveal {
      opacity: 1 !important;
      transform: none !important;
    }
    .port-card {
      opacity: 1 !important;
      transform: none !important;
    }
  }
</style>

<script>
  import gsap from "gsap";
  import ScrollTrigger from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const lineInners = gsap.utils.toArray<HTMLElement>(".port-line-inner");
  const reveals = gsap.utils.toArray<HTMLElement>(".port-reveal");
  const cards = gsap.utils.toArray<HTMLElement>(".port-card");
  const prefersReduced = window.matchMedia(
    "(prefers-reduced-motion: reduce)",
  ).matches;

  if (prefersReduced) {
    gsap.set(lineInners, { y: 0 });
    gsap.set(reveals, { y: 0, opacity: 1 });
    gsap.set(cards, { y: 0, opacity: 1 });
  } else {
    gsap.set(lineInners, { yPercent: 110 });
    gsap.set(reveals, { y: 20, opacity: 0 });
    gsap.set(cards, { y: 60, opacity: 0 });

    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: "#work",
        start: "top top",
        end: "+=160%",
        scrub: 0.6,
        pin: true,
        anticipatePin: 1,
      },
      defaults: { ease: "power3.out" },
    });

    tl.to(reveals, {
      y: 0,
      opacity: 1,
      duration: 0.4,
      stagger: 0.1,
    })
      .to(
        lineInners,
        {
          yPercent: 0,
          duration: 1,
          stagger: 0.28,
        },
        "-=0.2",
      )
      .to(
        cards,
        {
          y: 0,
          opacity: 1,
          duration: 0.8,
          stagger: 0.18,
        },
        "-=0.4",
      );
  }
</script>

---
import { site } from "../../data/site";
const { reasons, blurLines, mobileHeroText } = site.whyUs;
---

<section
  id="desktop-why-us"
  aria-label="Why Choose Us Desktop"
  class="relative h-[800vh] hidden lg:block"
>
  <div class="absolute inset-0 -z-10 bg-white/80 opacity-40">
    <div class="absolute inset-0 bg-[#e22472] opacity-30"></div>
  </div>

  <div class="sticky top-0 h-screen w-full overflow-hidden flex items-center">
    <div
      id="wu-image-wrapper"
      class="relative h-full w-0 shrink-0 overflow-hidden z-0"
    >
      <img
        id="wu-image"
        src="/images/collage_1.webp"
        alt="Why choose Virtex"
        class="h-full w-full object-cover origin-center"
      />
      <div id="wu-overlay" class="absolute inset-0 bg-black/70 opacity-0 z-10">
      </div>
    </div>

    <div class="shrink-0 pl-12 lg:pl-24 z-10">
      <h2
        id="wu-title"
        class="text-6xl md:text-8xl font-black uppercase tracking-tighter text-black whitespace-nowrap"
      >
        Why <em class="not-italic text-gradient">Us?</em>
      </h2>
    </div>

    <div
      id="wu-blur-stage"
      class="absolute inset-0 z-30 flex flex-col items-center justify-center pointer-events-none opacity-0 overflow-hidden"
    >
      <div
        id="wu-blur-lines"
        class="relative flex flex-col items-center max-w-5xl mx-auto px-6"
      >
        {
          blurLines.map((line, i) => (
            <p
              class="wu-blur-line text-3xl md:text-5xl lg:text-6xl font-bold text-white tracking-tight text-center my-3 opacity-0"
              data-index={i}
            >
              {line}
            </p>
          ))
        }
      </div>
    </div>

    <div
      id="wu-reasons-container"
      class="absolute inset-0 z-20 flex flex-col justify-center px-8 md:px-24 pointer-events-none opacity-0"
    >
      <div class="relative w-full z-20 pb-[20vh]">
        <div class="cards w-full md:w-[65%] mx-auto relative">
          {
            reasons.map(({ title, description, Icon }, index) => (
              <div class="card-wrapper relative w-full my-[30vh]">
                <div
                  class="card-inner w-full min-h-[50vh] rounded-3xl overflow-hidden relative flex flex-col justify-start p-10 md:p-14"
                  style="background: rgba(97, 97, 97, 0.45); border: 1px solid rgba(255,255,255,0.08); box-shadow: 0 30px 60px rgba(0,0,0,0.4);"
                >
                  <div
                    class="absolute inset-x-0 bottom-0 h-[65%] pointer-events-none z-0"
                    style="background: radial-gradient(circle at bottom center, rgba(226,36,114,0.4) 0%, rgba(159,55,148,0.15) 55%, transparent 85%); filter: blur(35px);"
                  />
                  <div class="card-depth-overlay absolute inset-0 bg-black z-10 pointer-events-none opacity-0 rounded-3xl" />

                  <div class="relative z-20 flex items-center justify-between mb-8 md:mb-10 w-full">
                    <div class="flex items-center justify-center w-16 h-16 rounded-2xl bg-white border border-white/10 shadow-lg backdrop-blur-md">
                      <Icon className="w-8 h-8" style="color: #e22472;" />
                    </div>
                    <span class="text-4xl md:text-5xl font-black text-white/10 tracking-tighter">
                      0{index + 1}
                    </span>
                  </div>

                  <div class="relative z-20 flex flex-col mt-auto">
                    <h3 class="text-3xl md:text-4xl font-bold text-white mb-4 tracking-tight">
                      {title}
                    </h3>
                    <p class="text-base md:text-lg text-zinc-300 leading-relaxed font-light">
                      {description}
                    </p>
                  </div>
                </div>
              </div>
            ))
          }
          <div
            id="cards-end-marker"
            class="absolute bottom-0 w-full h-10 pointer-events-none -mb-10"
          >
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<div class="block lg:hidden bg-[#050508]">
  <section id="mobile-hero" class="relative h-[200vh]">
    <div
      class="sticky top-0 h-screen w-full flex flex-col items-center justify-center overflow-hidden"
    >
      <div class="absolute inset-0 z-0">
        <img
          src="/images/collage_1.webp"
          alt="Why choose Virtex"
          class="h-full w-full object-cover"
        />
        <div class="absolute inset-0 bg-black/75 z-10"></div>
      </div>

      <div
        id="mobile-hero-content"
        class="relative z-20 flex flex-col items-center w-full"
      >
        <h2 class="text-6xl font-black uppercase tracking-tighter text-white">
          Why <em class="not-italic text-[#e22472]">Us?</em>
        </h2>

        <p
          id="mobile-wu-desc"
          class="mt-8 px-6 text-center text-lg font-medium text-zinc-300 leading-relaxed max-w-sm"
        >
          {mobileHeroText}
        </p>
      </div>
    </div>
  </section>

  <div class="relative z-20">
    <div
      class="w-full h-40 bg-gradient-to-b from-transparent to-[#050508] pointer-events-none -mb-1"
    >
    </div>

    <section
      id="mobile-reasons-list"
      class="bg-[#050508] pb-24 pt-4 px-6 border-none"
    >
      <div class="flex flex-col gap-12">
        {
          reasons.map(({ title, mobileDescription, Icon }, index) => (
            <div class="mobile-reason-item opacity-0 translate-y-10 flex flex-col gap-4">
              <div class="flex items-center gap-4">
                <div class="flex items-center justify-center w-12 h-12 rounded-xl bg-white/10 border border-white/20 shadow-lg">
                  <Icon size={24} color="#e22472" />
                </div>
                <span class="text-3xl font-black text-white/10 tracking-tighter ml-auto">
                  0{index + 1}
                </span>
              </div>

              <h3 class="text-2xl font-bold text-white tracking-tight">
                {title}
              </h3>

              <p class="text-base text-zinc-400 leading-relaxed font-light">
                {mobileDescription}
              </p>

              {index !== reasons.length - 1 && (
                <div class="w-full h-px bg-gradient-to-r from-white/10 to-transparent mt-6" />
              )}
            </div>
          ))
        }
      </div>
    </section>
  </div>
</div>

<style>
  /* Desktop Styles */
  #wu-image-wrapper,
  #wu-image,
  #wu-title,
  .wu-reveal {
    will-change: transform, opacity, width, filter;
    transform: translateZ(0);
  }
  .card-inner {
    will-change: transform, filter;
    transform: translateZ(0);
    backface-visibility: hidden;
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
  }
  .wu-blur-line {
    will-change: filter, opacity;
    line-height: 1.3;
  }

  /* Mobile Styles */
  .m-char {
    display: inline-block;
    will-change: opacity;
  }
</style>

<script>
  import gsap from "gsap";
  import ScrollTrigger from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  let ctx: gsap.Context | undefined;

  function initWhyUs() {
    ctx?.revert();

    let mm = gsap.matchMedia();

    ctx = gsap.context(() => {
      // ==============================================
      // 💻 DESKTOP TIMELINE (Displays at 1024px+)
      // ==============================================
      mm.add("(min-width: 1024px)", () => {
        const section = document.getElementById("desktop-why-us");
        const imageWrapper = document.getElementById("wu-image-wrapper");
        const image = document.getElementById("wu-image");
        const overlay = document.getElementById("wu-overlay");
        const title = document.getElementById("wu-title");
        const blurStage = document.getElementById("wu-blur-stage");
        const blurLinesBlock = document.getElementById("wu-blur-lines");
        const blurLines = gsap.utils.toArray<HTMLElement>(".wu-blur-line");
        const reasonsContainer = document.getElementById(
          "wu-reasons-container",
        );
        const cards = gsap.utils.toArray<HTMLElement>(".card-wrapper");

        if (!section) return;

        gsap.set(".cards", { height: "40vh" });

        cards.forEach((card, index) => {
          gsap.set(card, {
            position: "absolute",
            top: 0,
            left: 0,
            margin: 0,
            zIndex: index,
          });
          gsap.set(card.querySelector(".card-inner"), { filter: "blur(0px)" });
        });
        gsap.set(image, { filter: "blur(0px)" });

        const tl = gsap.timeline({
          scrollTrigger: {
            trigger: section,
            start: "top 90%",
            end: "bottom bottom",
            scrub: 1,
            invalidateOnRefresh: true,
          },
        });

        tl.to(
          imageWrapper,
          { width: "100vw", duration: 300, ease: "power1.inOut" },
          0,
        )
          .to(
            image,
            {
              scale: 1.15,
              filter: "blur(10px)",
              duration: 300,
              ease: "power1.inOut",
            },
            0,
          )
          .to(title, { y: "20vw", duration: 315, ease: "power1.inOut" }, 0)
          .to(overlay, { opacity: 1, duration: 310 }, 10);

        tl.to(blurStage, { opacity: 1, duration: 30 }, 200);

        const totalLines = blurLines.length;
        const lineGap = 45;
        const lineScrollWindow = 60;
        const lineHold = 15;

        tl.fromTo(
          blurLinesBlock,
          { y: "20vh" },
          {
            y: "-20vh",
            duration: totalLines * lineGap + lineScrollWindow * 2,
            ease: "none",
          },
          220,
        );

        blurLines.forEach((line, i) => {
          const startReveal = 220 + i * lineGap;
          tl.fromTo(
            line,
            { opacity: 0, filter: "blur(16px)" },
            {
              opacity: 1,
              filter: "blur(0px)",
              duration: lineScrollWindow,
              ease: "power2.out",
            },
            startReveal,
          );
          tl.to(
            line,
            {
              opacity: 0,
              filter: "blur(16px)",
              duration: lineScrollWindow,
              ease: "power2.in",
            },
            startReveal + lineScrollWindow + lineHold,
          );
        });

        const blurEnd =
          220 + totalLines * lineGap + lineScrollWindow * 2 + lineHold;
        tl.to(blurStage, { opacity: 0, duration: 30 }, blurEnd - 20);

        const cardsStart = blurEnd + 20;
        tl.to(reasonsContainer, { opacity: 1, duration: 40 }, cardsStart);

        let timelineOffset = cardsStart + 30;

        cards.forEach((card, index) => {
          tl.fromTo(
            card,
            { y: () => window.innerHeight },
            { y: 0, duration: 200, ease: "power2.out" },
            timelineOffset,
          );

          if (index > 0) {
            for (let j = 0; j < index; j++) {
              const inner = cards[j].querySelector(".card-inner");
              const shadow = cards[j].querySelector(".card-depth-overlay");
              const distance = index - j;

              tl.to(
                inner,
                {
                  scale: 1 - distance * 0.05,
                  y: -(distance * 35),
                  filter: `blur(${distance * 4}px)`,
                  duration: 200,
                  ease: "power2.out",
                },
                timelineOffset,
              );
              tl.to(
                shadow,
                { opacity: distance * 0.35, duration: 115, ease: "power2.out" },
                timelineOffset,
              );
            }
          }
          timelineOffset += 140;
        });

        const exitStart = timelineOffset + 20;
        const exitDuration = 120;

        tl.to(
          image,
          {
            filter: "blur(60px)",
            scale: 1.25,
            duration: exitDuration,
            ease: "power2.in",
          },
          exitStart,
        )
          .to(
            overlay,
            { opacity: 0.92, duration: exitDuration, ease: "power2.in" },
            exitStart,
          )
          .to(
            reasonsContainer,
            { opacity: 0, duration: exitDuration * 0.6, ease: "power2.in" },
            exitStart + exitDuration * 0.4,
          );
      });

      // ==============================================
      // 📱 MOBILE TIMELINE (Displays Below 1024px)
      // ==============================================
      mm.add("(max-width: 1023px)", () => {
        // 1. Manually Split Text (Keeping Native Spaces!)
        const descEl = document.getElementById("mobile-wu-desc");
        if (descEl) {
          const originalText = descEl.innerText;

          descEl.innerHTML = originalText
            .split("")
            .map((char) => {
              // If it's a space, render a native space outside the span so it wraps naturally
              if (char === " ") return " ";
              return `<span class="m-char opacity-0">${char}</span>`;
            })
            .join("");
        }

        // 2. Scrubbed Timeline for Hero Title & Text Reveal
        const heroTl = gsap.timeline({
          scrollTrigger: {
            trigger: "#mobile-hero",
            start: "top top",
            end: "bottom bottom",
            scrub: 1,
          },
        });

        heroTl
          // Move the entire content block (Title + Desc) up dramatically
          .to("#mobile-hero-content", { y: -50, duration: 1.5 })
          // Fade characters in one by one right after movement starts
          .to(".m-char", { opacity: 1, duration: 1.5, stagger: 0.05 }, "<0.2");

        // 3. Simple In-View Timeline for the List Items
        const listItems = gsap.utils.toArray<HTMLElement>(
          ".mobile-reason-item",
        );

        listItems.forEach((item) => {
          gsap.to(item, {
            scrollTrigger: {
              trigger: item,
              start: "top 85%",
            },
            opacity: 1,
            y: 0,
            duration: 0.6,
            ease: "power3.out",
          });
        });
      });
    });
  }

  document.addEventListener("astro:after-swap", () => ctx?.revert());
  document.addEventListener("astro:page-load", initWhyUs);

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initWhyUs);
  } else {
    initWhyUs();
  }
</script>

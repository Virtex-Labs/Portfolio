---
import { site } from "../data/site";

const allNavItems = [...site.nav_left, ...site.nav_right];
---

<header
  id="site-nav"
  aria-label="Site navigation"
  class="fixed inset-x-0 top-0 z-[100] transition-colors duration-500 bg-transparent"
>
  <nav
    class="mx-auto flex lg:grid h-[10vh] w-full lg:grid-cols-3 items-center justify-between px-6 lg:px-20 relative z-20"
  >
    <ul
      class="hidden lg:flex h-full w-full items-center justify-between gap-1 list-none p-0 m-0"
    >
      {
        site.nav_left.map((item) => (
          <li class="nav-item nav-left-item flex h-full">
            <a
              href={item.href}
              class="group relative flex h-full items-center px-4 text-lg font-[450] tracking-wide no-underline overflow-hidden"
            >
              <span class="relative block h-[1.3em] overflow-hidden">
                <span class="block transition-transform duration-500 ease-[cubic-bezier(0.76,0,0.24,1)] group-hover:-translate-y-full text-black">
                  {item.label}
                </span>
                <span class="absolute top-full left-0 block transition-transform duration-500 ease-[cubic-bezier(0.76,0,0.24,1)] group-hover:-translate-y-full bg-[#e22472] bg-clip-text text-transparent font-semibold">
                  {item.label}
                </span>
              </span>
              <span class="absolute top-0 left-0 h-[3px] w-full origin-center scale-x-0 bg-gradient-to-r from-[#9f3794] via-[#e22472] to-[#9f3794] transition-transform duration-500 ease-[cubic-bezier(0.76,0,0.24,1)] group-hover:scale-x-100" />
            </a>
          </li>
        ))
      }
    </ul>

    <div
      class="nav-brand flex h-full items-center justify-start lg:justify-center"
      aria-label="Home"
    >
      <a href="/" class="flex items-center no-underline relative z-50">
        <slot name="brand">
          <img
            src="/wordmark.svg"
            alt={site.name}
            class="h-20 lg:h-24 w-auto object-contain transition-transform duration-300"
            id="nav-logo-img"
          />
        </slot>
      </a>
    </div>

    <div class="hidden lg:flex h-full items-center justify-end gap-1">
      <ul
        class="flex h-full w-full items-center justify-between gap-1 list-none p-0 m-0"
      >
        {
          site.nav_right.map((item) => (
            <li class="nav-item nav-right-item flex h-full">
              <a
                href={item.href}
                class="group relative flex h-full items-center px-4 text-lg font-[450] tracking-wide no-underline overflow-hidden"
              >
                <span class="relative block h-[1.3em] overflow-hidden">
                  <span class="block transition-transform duration-500 ease-[cubic-bezier(0.76,0,0.24,1)] group-hover:-translate-y-full text-black">
                    {item.label}
                  </span>
                  <span class="absolute top-full left-0 block transition-transform duration-500 ease-[cubic-bezier(0.76,0,0.24,1)] group-hover:-translate-y-full bg-[#e22472] bg-clip-text text-transparent font-semibold">
                    {item.label}
                  </span>
                </span>
                <span class="absolute top-0 left-0 h-[3px] w-full origin-center scale-x-0 bg-gradient-to-r from-[#9f3794] via-[#e22472] to-[#9f3794] transition-transform duration-500 ease-[cubic-bezier(0.76,0,0.24,1)] group-hover:scale-x-100" />
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <button
      id="mobile-menu-toggle"
      class="lg:hidden relative z-50 flex flex-col justify-center items-center w-12 h-12 gap-1.5 focus:outline-none"
      aria-label="Toggle Menu"
    >
      <span
        class="hamburger-line w-8 h-[2px] bg-black block transition-all duration-300 origin-center"
      ></span>
      <span
        class="hamburger-line w-8 h-[2px] bg-black block transition-all duration-300 origin-center"
      ></span>
    </button>
  </nav>
</header>

<div
  id="mobile-overlay"
  class="fixed inset-0 bg-white z-50 flex flex-col items-center justify-center pointer-events-none"
>
  <div class="absolute inset-0 pointer-events-none overflow-hidden z-0"></div>

  <ul class="flex flex-col items-center gap-8 z-10 w-full px-6 text-center">
    {
      allNavItems.map((item) => (
        <li class="mobile-nav-link-wrap overflow-hidden w-full">
          <a
            href={item.href}
            class="mobile-nav-link block text-4xl sm:text-5xl font-black uppercase tracking-widest text-zinc-900 hover:text-[#e22472] transition-colors translate-y-[120%] will-change-transform"
          >
            {item.label}
          </a>
        </li>
      ))
    }
  </ul>

  <div
    class="mobile-nav-footer absolute bottom-10 w-full text-center opacity-0"
  >
    <p class="text-zinc-500 text-xs tracking-[0.2em] font-medium uppercase">
      Virtex Labs &copy; {new Date().getFullYear()}
    </p>
  </div>
</div>

<style>
  @media (prefers-reduced-motion: reduce) {
    #site-nav {
      height: 10vh;
    }
    #site-nav,
    .nav-item,
    .mobile-nav-link,
    #mobile-overlay {
      opacity: 1 !important;
      transform: none !important;
    }
  }

  /* Hamburger Active States */
  #mobile-menu-toggle.is-open .hamburger-line:nth-child(1) {
    transform: translateY(4px) rotate(45deg);
    background-color: #050508 !important;
  }
  #mobile-menu-toggle.is-open .hamburger-line:nth-child(2) {
    transform: translateY(-4px) rotate(-45deg);
    background-color: #050508 !important;
  }
</style>

<script>
  import gsap from "gsap";
  import ScrollTrigger from "gsap/ScrollTrigger";
  import { isMobile } from "get-browser";

  gsap.registerPlugin(ScrollTrigger);

  const header = document.getElementById("site-nav");
  const leftItems = Array.from(document.querySelectorAll(".nav-left-item"));
  const rightItems = Array.from(document.querySelectorAll(".nav-right-item"));
  const brand = document.querySelector(".nav-brand");

  const menuToggle = document.getElementById("mobile-menu-toggle");
  const mobileOverlay = document.getElementById("mobile-overlay");
  const mobileLinks = gsap.utils.toArray(".mobile-nav-link");
  const mobileFooter = document.querySelector(".mobile-nav-footer");
  const logoImg = document.getElementById("nav-logo-img");

  const LOGO_EVENT = "vl-logo-complete";
  const userAgent = navigator.userAgent || "";
  const mobileDevice = isMobile({ userAgent });

  if (!header) throw new Error("Site navigation element not found.");

  const prefersReduced = window.matchMedia(
    "(prefers-reduced-motion: reduce)",
  ).matches;

  // ─── INITIAL DESKTOP NAV REVEAL ───
  function startNavAnimation() {
    const tl = gsap.timeline({
      delay: mobileDevice ? 0.9 : 0.85,
      defaults: { ease: "power3.out" },
    });
    tl.to(header, { opacity: 1, y: 0, duration: 0.55 })
      .to(brand, { opacity: 1, duration: 0.4 }, "-=0.25")
      .to(
        leftItems,
        { opacity: 1, x: 0, duration: 0.5, stagger: 0.08 },
        "-=0.3",
      )
      .to(
        rightItems,
        {
          opacity: 1,
          x: 0,
          duration: 0.5,
          stagger: { each: 0.08, from: "end" },
        },
        "<",
      );
  }

  if (!prefersReduced) {
    gsap.set(header, { opacity: 0, y: -24 });
    gsap.set(leftItems, { opacity: 0, x: -22 });
    gsap.set(rightItems, { opacity: 0, x: 22 });
    if (brand) gsap.set(brand, { opacity: 0 });

    if (window.__vlLogoDone === true) {
      startNavAnimation();
    } else {
      window.addEventListener(
        LOGO_EVENT,
        () => {
          if (window.__vlLogoDone === true) startNavAnimation();
        },
        { once: true },
      );

      setTimeout(() => {
        if (window.__vlLogoDone !== true) startNavAnimation();
      }, 2200);
    }
  }

  // ─── MOBILE MENU LOGIC ───
  let isMenuOpen = false;
  let menuAnimation;

  if (menuToggle && mobileOverlay) {
    gsap.set(mobileOverlay, { yPercent: -100 });

    menuAnimation = gsap
      .timeline({
        paused: true,
        defaults: { ease: "power4.inOut" },
      })
      .to(mobileOverlay, { yPercent: 0, pointerEvents: "auto", duration: 0.6 })
      .to(
        mobileLinks,
        { y: 0, duration: 0.6, stagger: 0.06, ease: "power4.out" },
        "-=0.3",
      )
      .to(mobileFooter, { opacity: 1, duration: 0.4 }, "-=0.3");

    menuToggle.addEventListener("click", () => {
      isMenuOpen = !isMenuOpen;

      if (isMenuOpen) {
        menuToggle.classList.add("is-open");
        if (window.__lenis) window.__lenis.stop();

        // Force header white so hamburger button stays visible on dark overlays
        header.classList.add("bg-white");
        header.classList.remove("bg-transparent");

        menuAnimation.timeScale(1).play();
      } else {
        menuToggle.classList.remove("is-open");
        if (window.__lenis) window.__lenis.start();

        // Restore dynamic background logic
        if (window.scrollY < 50) {
          header.classList.remove("bg-white");
          header.classList.add("bg-transparent");
        }

        menuAnimation.timeScale(1.5).reverse();
      }
    });

    mobileLinks.forEach((link) => {
      link.addEventListener("click", () => {
        if (isMenuOpen) menuToggle.click();
      });
    });
  }

  // ─── BULLETPROOF GSAP SCROLL LOGIC ───
  let isNavHidden = false;

  ScrollTrigger.create({
    start: "top top",
    end: "max",
    onUpdate: (self) => {
      // Abort all scroll logic if the mobile menu is open
      if (isMenuOpen) return;

      const currentY = window.scrollY;

      // 1. Dynamic Background Color
      if (currentY > 50) {
        header.classList.add("bg-white");
        header.classList.remove("bg-transparent");
      } else {
        header.classList.remove("bg-white");
        header.classList.add("bg-transparent");
      }

      // 2. Data-Hide-Nav Overlap Check (Hides nav entirely on dark sections)
      let forceHide = false;
      document.querySelectorAll("[data-hide-nav]").forEach((section) => {
        const rect = section.getBoundingClientRect();
        // If the section is touching the header
        if (rect.top <= header.offsetHeight && rect.bottom > 0) {
          forceHide = true;
        }
      });

      // 3. Flawless Visibility State Machine
      if (forceHide) {
        if (!isNavHidden) {
          gsap.to(header, {
            yPercent: -100,
            duration: 1,
            ease: "power2.inOut",
            overwrite: "auto",
          });
          isNavHidden = true;
        }
      } else {
        // self.direction: 1 is scrolling down, -1 is scrolling up
        if (self.direction === 1 && !isNavHidden && currentY > 100) {
          // Hide on scroll down
          gsap.to(header, {
            yPercent: -100,
            duration: 1,
            ease: "power2.inOut",
            overwrite: "auto",
          });
          isNavHidden = true;
        } else if (self.direction === -1 && isNavHidden) {
          // Show on scroll up
          gsap.to(header, {
            yPercent: 0,
            duration: 1,
            ease: "power3.out",
            overwrite: "auto",
          });
          isNavHidden = false;
        }
      }
    },
  });
</script>

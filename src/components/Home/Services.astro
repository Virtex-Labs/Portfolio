---
import { site } from "../../data/site";
import ServiceModal from "./ServiceModal.astro";
const services = site.services;
---

<section
  id="desktop-services"
  aria-label="Find the service you need"
  class="hidden sm:pt-72 lg:block relative w-full bg-[#fcf2f6] py-32 overflow-hidden z-10"
>
  <div class="w-full max-w-screen-2xl mx-auto px-10">
    <div class="flex items-start justify-between mb-24">
      <h2
        class="text-[#050505] text-7xl xl:text-[5.5rem] font-black tracking-tighter leading-[0.95] max-w-2xl"
      >
        Find the service <br />
        <span class="text-gradient">you need</span>
      </h2>
    </div>

    <div
      class="flex flex-col items-center justify-center w-full relative space-y-[-1vw]"
    >
      {
        services.map((service, index) => (
          <div
            class="service-trigger group relative cursor-pointer w-full flex flex-col items-center py-6 border-b border-black/5 last:border-none"
            data-service={JSON.stringify(service)}
          >
            <div class="relative w-full flex justify-center items-center">
              <span class="absolute -left-[5%] top-4 text-sm font-bold text-black opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                0{index + 1}.
              </span>

              <h3 class="desktop-service-title text-[7.5vw] font-black leading-none tracking-tighter text-[#eca0be]/60 transition-colors duration-500 group-hover:text-[#050505] text-center w-full m-0">
                {service.title}
              </h3>

              <div class="absolute -right-[9%] top-1/2 -translate-y-1/2 w-40 opacity-0 group-hover:opacity-100 transition-all duration-500 pointer-events-none text-right translate-x-4 group-hover:translate-x-0 z-20">
                <p class="text-sm font-medium leading-tight text-black mb-4">
                  {service.description_short}
                </p>
                <span class="inline-flex items-center text-sm font-bold text-black">
                  <span class="mr-2">↳</span> More Info
                </span>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<section
  id="mobile-services"
  aria-label="Find the service you need mobile"
  class="block lg:hidden relative w-full bg-[#fcf2f6] py-24 px-4 overflow-hidden z-10"
>
  <div class="relative mb-16 px-2">
    <h2
      class="text-[#050505] text-[3.5rem] font-black tracking-tighter leading-[0.95]"
    >
      Find the service<br />
      <span class="text-gradient">you need</span>
    </h2>
  </div>

  <div class="grid grid-cols-2 gap-3 items-start">
    {
      services.map((service, index) => (
        <div
          class={`service-trigger mobile-card bg-[#f6a9c8] p-5 rounded-md cursor-pointer shadow-sm hover:shadow-md transition-shadow flex flex-col min-h-[32vh] ${
            index % 2 !== 0 ? "mt-12" : ""
          }`}
          data-service={JSON.stringify(service)}
        >
          <h3 class="text-white text-xl font-black tracking-tight leading-[1.05] mb-4">
            {service.title}
          </h3>
          <p class="text-white/90 text-[13px] font-medium leading-snug mb-8 line-clamp-4">
            {service.description}
          </p>
          <div class="mt-auto">
            <span class="inline-flex items-center text-[#050505] text-sm font-bold">
              <span class="mr-1">↳</span> More Info
            </span>
          </div>
        </div>
      ))
    }
  </div>
</section>

<ServiceModal />

<script>
  import gsap from "gsap";
  import ScrollTrigger from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  let mm: gsap.MatchMedia;

  function initServices() {
    if (mm) mm.revert();
    mm = gsap.matchMedia();

    mm.add("(min-width: 1024px)", () => {
      const titles = gsap.utils.toArray(".desktop-service-title");

      titles.forEach((title: any) => {
        gsap.fromTo(
          title,
          { y: 80, opacity: 0 },
          {
            y: 0,
            opacity: 1,
            duration: 1,
            ease: "power3.out",
            scrollTrigger: {
              trigger: title,
              start: "top 90%",
              toggleActions: "play none none reverse",
            },
          },
        );
      });
    });

    mm.add("(max-width: 1023px)", () => {
      const cards = gsap.utils.toArray(".mobile-card");

      cards.forEach((card: any, i) => {
        gsap.fromTo(
          card,
          { y: 60, opacity: 0 },
          {
            y: 0,
            opacity: 1,
            duration: 0.8,
            ease: "power2.out",
            delay: (i % 2) * 0.1,
            scrollTrigger: {
              trigger: card,
              start: "top 85%",
              toggleActions: "play none none reverse",
            },
          },
        );
      });
    });

    ScrollTrigger.refresh();
  }

  document.addEventListener("astro:after-swap", () => {
    if (mm) mm.revert();
  });

  document.addEventListener("astro:page-load", initServices);

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initServices);
  } else {
    initServices();
  }
</script>

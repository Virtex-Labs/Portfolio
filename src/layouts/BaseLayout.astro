---
import Navbar from "../components/Navbar.astro";
import LandscapeWarning from "../components/LandscapeWarning.astro";
import CookieBanner from "../components/CookieBanner.astro";
import PageTransition from "../providers/PageTransition.astro";
import PageLayout from "./PageLayout.astro";
import "../styles/global.css";

const { title, description } = Astro.props;
---

<PageLayout title={title} description={description}>
  <Fragment slot="head">
    <script is:inline>
      if ("scrollRestoration" in history) {
        history.scrollRestoration = "manual";
      }
      window.scrollTo(0, 0);
      window.addEventListener("pageshow", () => {
        window.scrollTo(0, 0);
      });

      // WebMCP Support for AI Agents
      if (typeof navigator !== 'undefined' && 'modelContext' in navigator) {
        // @ts-ignore
        navigator.modelContext.provideContext({
          tools: [
            {
              name: "get_portfolio_info",
              description: "Returns basic information about this portfolio",
              inputSchema: { type: "object", properties: {} },
              execute: async () => {
                return { content: [{ type: "text", text: "This is the portfolio of Virtex Labs." }] };
              }
            }
          ]
        });
      }
    </script>
  </Fragment>

  <LandscapeWarning />
  <Navbar />
  <CookieBanner />

  <main>
    <slot />
  </main>
  <PageTransition />

  <script>
    import "../scripts/animations.ts";
  </script>
</PageLayout>
